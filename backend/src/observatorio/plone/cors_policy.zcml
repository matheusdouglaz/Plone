<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:plone="http://namespaces.plone.org/plone"
    >
  <!--
    Uma única CORSPolicy (substitui o pacote plone.volto.cors, que registaria a mesma
    utilidade e causaria ConfigurationConflictError). Origens: dev Volto + produção.
  -->
  <plone:CORSPolicy
      allow_origin="http://localhost:3000,http://127.0.0.1:3000,https://volto.observatorio.gov.br,https://plone-front.onrender.com"
      allow_credentials="true"
      allow_methods="DELETE,GET,OPTIONS,PATCH,POST,PUT"
      expose_headers="Content-Length,X-My-Header"
      allow_headers="Accept,Authorization,Content-Type,Origin,X-Custom-Header,Lock-Token"
      max_age="3600"
      />
</configure>
